<html>
<body>

<h2>Add Schedule</h2>

<form action="AddScheduleServlet" method="post">

    Route ID: <input type="text" name="routeId"><br><br>

    Plate Number: <input type="text" name="plateNumber"><br><br>

    Departure Date: <input type="date" name="departureDate"><br><br>

    Departure Time: <input type="time" name="departureTime"><br><br>

    Arrival Time: <input type="time" name="arrivalTime"><br><br>

    Driver Name: <input type="text" name="driverName"><br><br>

    Available Seats: <input type="number" name="availableSeats"><br><br>

    <input type="submit" value="Add Schedule">

</form>

</body>
</html>